# Environment Variables — Copy this to .env in backend/

PORT=5000

# MongoDB Atlas — Replace with your actual connection string
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/careercracker?retryWrites=true&w=majority

# JWT Secrets — Use long random strings (min 32 chars each)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars

# Token expiry
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
